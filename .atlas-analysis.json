  "keyFeatures": [
    "Product catalog with camera specifications",
    "Advanced filtering by brand, resolution, design, and type",
    "Detailed camera view with image gallery",
    "Redux state management for product data",
    "React Router for SPA navigation",
    "WhatsApp integration for customer contact",
    "Responsive design with Bootstrap",
    "Multi-page layout (home, products, about, contact)"
  ],
  "publicApiSurface": [
    "App - Main application component",
    "Principal - Landing page component",
    "Main - Product listing page",
    "NavbarTop - Top navigation bar",
    "NavbarAside - Sidebar filter navigation",
    "ListCam - Camera list component",
    "CardsCamara - Individual camera card",
    "ViewCamera - Detailed camera view",
    "FilterCamara - Filtered camera results",
    "Contacto - Contact page",
    "Nosotros - About us page",
    "WhatsappIcon - Floating WhatsApp button",
    "camarasSlice - Redux slice for camera state",
    "store - Redux store configuration",
    "filterCamara - Action to filter cameras by ID",
    "filterModelo - Action to filter cameras by model",
    "filterCamarasAside - Action to filter by multiple criteria",
    "backToInitialState - Action to reset camera state"
  ]
}
